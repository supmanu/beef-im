---
interface Props {
  line1: string;
  line2: string;
}
const { line1, line2 } = Astro.props;
---
<div class="nb-verdict">
  <div class="nb-verdict-label"><slot /></div>
  <div class="nb-verdict-circle">
    <svg viewBox="0 0 100 100">
      <ellipse class="cp" cx="50" cy="50" rx="44" ry="42" transform="rotate(-3 50 50)"/>
      <text x="50" y="45" style="font-family:'Anuphan',sans-serif;font-weight:700;font-size:11px;fill:var(--color-red);text-anchor:middle">{line1}</text>
      <text x="50" y="57" style="font-family:'Anuphan',sans-serif;font-weight:700;font-size:11px;fill:var(--color-red);text-anchor:middle">{line2}</text>
    </svg>
  </div>
</div>
