---
import HeroSketch from './HeroSketch.astro';
import Navbar from './Navbar.astro';
---
<section class="hero" id="hero">
  <div class="hero-grid" aria-hidden="true"></div>
  <div class="hero-watermark" aria-hidden="true">เนื้อ</div>
  <div class="hero-sunburst" aria-hidden="true"></div>

  <Navbar />

  <div class="hero-content">
    <div class="hero-rule-container"><div class="hero-rule"></div></div>
    <div class="hero-eyebrow"><span>CASE FILE № 04 · POLICY TEARDOWN</span></div>
    <h1 class="hero-h">ดูเนื้อ <span class="accent">ไม่ดูหน้า</span></h1>
    <!-- Fountain-pen flourish — draws on every visit -->
    <svg class="hero-flourish" viewBox="0 0 360 24" aria-hidden="true">
      <path d="M2 16 C 60 4, 120 24, 180 12 C 240 0, 300 22, 358 8" />
    </svg>
    <p class="hero-sub">Contract forensics · Grill technique · No filler</p>
    <a class="hero-cta" href="#journal">เปิดสมุดบันทึก</a>
  </div>

  <HeroSketch />

</section>

<style>
/* Fountain-pen flourish */
.hero-flourish {
  width: clamp(180px, 32vw, 360px);
  height: auto;
  margin: 6px auto 0;
  display: block;
}
.hero-flourish path {
  fill: none;
  stroke: #CC3A2F;
  stroke-width: 2;
  stroke-linecap: round;
  stroke-dasharray: 720;
  stroke-dashoffset: 720;
  animation: pen-draw 1.0s ease-out 0.6s forwards;
}
@keyframes pen-draw {
  to { stroke-dashoffset: 0; }
}

</style>
