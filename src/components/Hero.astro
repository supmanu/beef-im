---
import HeroSketch from './HeroSketch.astro';
import Navbar from './Navbar.astro';
---
<section class="hero" id="hero">
  <div class="hero-watermark" aria-hidden="true">เนื้อ</div>
  <div class="hero-sunburst" aria-hidden="true"></div>

  <Navbar />

  <div class="hero-content">
    <div class="hero-rule-container"><div class="hero-rule"></div></div>
    <div class="hero-eyebrow"><span>CASE FILE № 04 · POLICY TEARDOWN</span></div>
    <h1 class="hero-h">ดูเนื้อ <span class="accent">ไม่ดูหน้า</span></h1>
    <p class="hero-sub">Contract forensics · Grill technique · No filler</p>
    <a class="hero-cta" href="#homepage">เปิดสมุดบันทึก</a>
  </div>

  <HeroSketch />

  <div class="hero-down">
    <span>เปิดสมุด</span>
    <svg width="18" height="22" viewBox="0 0 14 16"><line x1="7" y1="0" x2="7" y2="10"/><line x1="3" y1="6" x2="7" y2="10"/><line x1="11" y1="6" x2="7" y2="10"/></svg>
  </div>
</section>

<script is:inline>
  document.addEventListener('DOMContentLoaded', function () {
    var isOpening = false;

    function doOpenNotebook() {
      if (isOpening) return;
      isOpening = true;

      // Remove all scroll triggers immediately
      window.removeEventListener('wheel', onWheel);
      window.removeEventListener('touchstart', onTouchStart);
      window.removeEventListener('touchmove', onTouchMove);

      var hero = document.getElementById('hero');
      var homepage = document.getElementById('homepage');
      if (!hero || !homepage) return;

      // Reduced motion: instant hide + scroll
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        hero.style.display = 'none';
        homepage.scrollIntoView({ behavior: 'smooth' });
        return;
      }

      // Lift hero out of flow so homepage reveals beneath
      hero.style.position = 'fixed';
      hero.style.inset = '0';
      hero.style.zIndex = '50';

      // Double rAF: fixed-position paint must complete before transform fires
      requestAnimationFrame(function () {
        requestAnimationFrame(function () {
          hero.classList.add('is-opening');
        });
      });

      // After flip: reset hero to normal flow while keeping it invisible,
      // THEN scroll — so the scroll offset accounts for hero's 100vh height.
      hero.addEventListener('transitionend', function done(evt) {
        if (evt.propertyName !== 'transform') return;
        hero.removeEventListener('transitionend', done);

        requestAnimationFrame(function () {
          // 1. Freeze transitions to prevent reverse-animate
          hero.style.transition = 'none';
          // 2. Pin opacity=0 via inline style so hero stays invisible
          hero.style.opacity = '0';
          // 3. Clear is-opening (removes transform) — opacity held by inline style
          hero.classList.remove('is-opening');
          // 4. Return hero to normal document flow (position: relative)
          hero.style.position = '';
          hero.style.inset = '';
          hero.style.zIndex = '';
          // 5. Force reflow — hero now occupies its 100vh in the layout
          void hero.offsetHeight;
          // 6. Scroll to homepage — correct offset now that hero is in flow
          homepage.scrollIntoView({ behavior: 'instant' });

          // 7. Restore hero visibility above the fold (no flash — it's off-screen)
          requestAnimationFrame(function () {
            hero.style.opacity = '';
            hero.style.transition = '';
          });
        });
      });
    }

    function onWheel(e) {
      if (e.deltaY > 0) {
        e.preventDefault();
        doOpenNotebook();
      }
    }

    var touchStartY = 0;
    function onTouchStart(e) {
      touchStartY = e.touches[0].clientY;
    }
    function onTouchMove(e) {
      if (touchStartY - e.touches[0].clientY > 40) {
        doOpenNotebook();
      }
    }

    // Click triggers
    var cta = document.querySelector('.hero-cta');
    var down = document.querySelector('.hero-down');
    if (cta) cta.addEventListener('click', function (e) { e.preventDefault(); doOpenNotebook(); });
    if (down) down.addEventListener('click', function (e) { e.preventDefault(); doOpenNotebook(); });

    // Scroll triggers
    window.addEventListener('wheel', onWheel, { passive: false });
    window.addEventListener('touchstart', onTouchStart, { passive: true });
    window.addEventListener('touchmove', onTouchMove, { passive: true });
  });
</script>
