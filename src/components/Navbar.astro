---
const now = new Date();
const days = ['SUN', 'MON', 'TUE', 'WED', 'THU', 'FRI', 'SAT'];
const months = ['JAN', 'FEB', 'MAR', 'APR', 'MAY', 'JUN', 'JUL', 'AUG', 'SEP', 'OCT', 'NOV', 'DEC'];
const formattedDate = `${days[now.getDay()]} · ${now.getDate().toString().padStart(2, '0')} ${months[now.getMonth()]} ${now.getFullYear().toString().slice(-2)}`;
---
<nav class="hero-nav">
  <a href="/" class="hero-brand">ประกันเนื้อๆ<small>BEEF · IM · JOURNAL</small></a>
  <div class="hero-nav-right" id="hero-date-display">{formattedDate}</div>
</nav>

<style>
.hero-brand {
  transition: color 0.35s ease;
  position: relative;
}
.hero-brand::after {
  content: '';
  position: absolute;
  bottom: -2px;
  left: 0;
  width: 0;
  height: 1.5px;
  background: #CC3A2F;
  transition: width 0.4s ease;
}
.hero-brand:hover {
  color: var(--color-burn);
}
.hero-brand:hover::after {
  width: 100%;
}
</style>

<script is:inline>
  function updateHeroDate() {
    const now = new Date();
    const days = ['SUN', 'MON', 'TUE', 'WED', 'THU', 'FRI', 'SAT'];
    const months = ['JAN', 'FEB', 'MAR', 'APR', 'MAY', 'JUN', 'JUL', 'AUG', 'SEP', 'OCT', 'NOV', 'DEC'];
    const formatted = `${days[now.getDay()]} · ${now.getDate().toString().padStart(2, '0')} ${months[now.getMonth()]} ${now.getFullYear().toString().slice(-2)}`;
    const el = document.getElementById('hero-date-display');
    if (el) el.textContent = formatted;
  }
  // Run immediately and also every hour just in case
  updateHeroDate();
  setInterval(updateHeroDate, 3600000);
</script>
