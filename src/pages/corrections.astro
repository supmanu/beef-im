---
import StaticPageLayout from '../layouts/StaticPageLayout.astro';
import { corrections } from '../data/corrections';
---
<StaticPageLayout
  title="บันทึกการแก้ไข"
  description="รายการแก้ไขข้อเท็จจริงทั้งหมดใน beef.im — วันที่ บทความ และสิ่งที่เปลี่ยน"
>
  <span class="sp-eyebrow">CORRECTIONS</span>
  <h1>บันทึกการแก้ไข</h1>
  <hr class="sp-rule" />

  <p>
    เมื่อข้อเท็จจริงในบทความใดผิดพลาด จะบันทึกการแก้ไขที่นี่พร้อมวันที่
    ไม่ลบ ไม่แก้เงียบ
  </p>

  {corrections.length === 0 ? (
    <p class="cor-empty">ยังไม่มีการแก้ไข — นี่เป็นสิ่งที่ดี</p>
  ) : (
    <table class="cor-table">
      <thead>
        <tr>
          <th>วันที่</th>
          <th>บทความ</th>
          <th>รายละเอียด</th>
        </tr>
      </thead>
      <tbody>
        {corrections.map(c => (
          <tr>
            <td class="cor-date">{c.date}</td>
            <td><a href={`/${c.articleSlug}/`} class="cor-link">{c.articleTitle}</a></td>
            <td>{c.summary}</td>
          </tr>
        ))}
      </tbody>
    </table>
  )}
</StaticPageLayout>

<style>
.cor-empty {
  font-family: var(--font-mono);
  font-size: 13px;
  color: rgba(27,26,23,0.45);
  letter-spacing: 0.04em;
  margin-top: 32px;
}
.cor-table {
  width: 100%;
  border-collapse: collapse;
  font-family: var(--font-thai);
  font-size: 14px;
  margin-top: 24px;
}
.cor-table th {
  font-family: var(--font-mono);
  font-size: 10px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: rgba(27,26,23,0.45);
  text-align: left;
  padding: 6px 12px 6px 0;
  border-bottom: 1px solid rgba(120,100,75,0.2);
}
.cor-table td {
  padding: 10px 12px 10px 0;
  border-bottom: 1px solid rgba(120,100,75,0.1);
  vertical-align: top;
  color: #2A2724;
}
.cor-date {
  font-family: var(--font-mono) !important;
  font-size: 11px !important;
  white-space: nowrap;
  color: rgba(27,26,23,0.5) !important;
}
.cor-link {
  color: #B85C38;
  text-decoration: none;
}
.cor-link:hover { text-decoration: underline; }
</style>
