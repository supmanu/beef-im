---
import { getCollection, render } from 'astro:content';
import ArticleLayout from '../layouts/ArticleLayout.astro';
import Highlight from '../components/mdx/Highlight.astro';
import MarginNote from '../components/mdx/MarginNote.astro';
import ScrapCard from '../components/mdx/ScrapCard.astro';
import CorrectionBlock from '../components/mdx/CorrectionBlock.astro';
import VerdictSeal from '../components/mdx/VerdictSeal.astro';

export async function getStaticPaths() {
  const collectionNames = ['insurance', 'meat', 'note'] as const;
  const allEntries = (
    await Promise.all(collectionNames.map(c => getCollection(c)))
  ).flat();

  return allEntries.map(entry => ({
    params: { slug: `${entry.collection}/${entry.id}` },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const d = new Date(entry.data.date);
const formattedDate = `${d.getDate()} ${d.toLocaleString('th-TH', { month: 'short' })} ${d.getFullYear()}`;

// footerType derived from collection — not in frontmatter
const footerType = entry.collection === 'insurance' ? 'analysis'
                 : entry.collection === 'meat'      ? 'beef'
                 : 'note';

// MDX components auto-injected — no imports needed inside .mdx files
const mdxComponents = { Highlight, MarginNote, ScrapCard, CorrectionBlock, VerdictSeal };
---
<ArticleLayout
  title={entry.data.title}
  collection={entry.collection}
  format={entry.data.format}
  date={formattedDate}
  footerType={footerType}
  description={entry.data.lede}
  code={entry.data.code}
  sidenote={entry.data.sidenote}
>
  <h2 class="nb-h">{entry.data.title}</h2>
  <div class="nb-byline">{formattedDate}</div>
  <div class="nb-rule-red"></div>
  <Content components={mdxComponents} />
</ArticleLayout>
