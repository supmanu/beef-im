---
import { getCollection, render } from 'astro:content';
import ArticleLayout from '../layouts/ArticleLayout.astro';
import Highlight from '../components/mdx/Highlight.astro';
import MarginNote from '../components/mdx/MarginNote.astro';
import ScrapCard from '../components/mdx/ScrapCard.astro';
import CorrectionBlock from '../components/mdx/CorrectionBlock.astro';
import VerdictSeal from '../components/mdx/VerdictSeal.astro';

export async function getStaticPaths() {
  const caseEntries = await getCollection('case');
  const expEntries = await getCollection('experiment');
  const fieldEntries = await getCollection('field-note');

  const allEntries = [...caseEntries, ...expEntries, ...fieldEntries];

  return allEntries.map(entry => ({
    params: { slug: `${entry.data.category}/${entry.id}` },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const d = new Date(entry.data.date);
const formattedDate = `${d.getDate()} ${d.toLocaleString('th-TH', { month: 'short' })} ${d.getFullYear()}`;

// MDX components auto-injected — no imports needed inside .mdx files
const mdxComponents = { Highlight, MarginNote, ScrapCard, CorrectionBlock, VerdictSeal };
---
<ArticleLayout
  title={entry.data.title}
  category={entry.data.category}
  date={formattedDate}
  footerType={entry.data.footerType}
  description={entry.data.lede}
>
  <h2 class="nb-h">{entry.data.title}</h2>
  <div class="nb-byline">{formattedDate} · {entry.data.author}</div>
  <div class="nb-rule-red"></div>
  <Content components={mdxComponents} />
</ArticleLayout>
