---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import NotebookEntry from '../components/NotebookEntry.astro';
import { getCollection } from 'astro:content';

const insuranceEntries = await getCollection('insurance');
const meatEntries      = await getCollection('meat');
const noteEntries      = await getCollection('note');

const allEntries = [...insuranceEntries, ...meatEntries, ...noteEntries].sort((a, b) => {
  return b.data.date.valueOf() - a.data.date.valueOf();
});
---
<BaseLayout title="ประกันเนื้อๆ — BEEF · IM · JOURNAL" bodyClass="home">
  <Hero />
  <section class="homepage" id="journal">
    <div class="hp-container">
      <div class="hp-header">
        <span class="hp-header-left">สมุดบันทึก</span>
        <span class="hp-header-right">JOURNAL</span>
      </div>
      <div class="hp-header-rule"></div>

      {allEntries.map((entry, i) => (
        <NotebookEntry
          index={allEntries.length - i}
          slug={entry.id}
          collection={entry.collection}
          format={entry.data.format}
          title={entry.data.title}
          lede={entry.data.lede}
          sidenote={entry.data.sidenote}
          temperature={entry.data.temperature}
          code={entry.data.code}
          wordCount={entry.data.wordCount}
          readTime={entry.data.readTime}
          latest={entry.data.latest}
        />
      ))}

      <div class="nb-home-footer">— จบเล่ม —</div>
    </div>
  </section>

<script is:inline>
  function initReveal() {
    var container = document.querySelector('.hp-container');
    if (!container || container.dataset.inkInit) return;

    var header = container.querySelector('.hp-header');
    var rule   = container.querySelector('.hp-header-rule');
    var entries = Array.from(container.querySelectorAll('.nb-entry'));

    // Batch all rect reads before any writes to avoid forced reflow.
    var vh = window.innerHeight;
    var tops = entries.map(function (entry) { return entry.getBoundingClientRect().top; });

    // All writes come after all reads — no DOM mutation before geometry queries.
    container.dataset.inkInit = '1';
    container.classList.add('js-ink-init');
    var slot = 0;
    entries.forEach(function (entry, i) {
      if (tops[i] < vh && slot < 5) {
        entry.style.animationDelay = (160 + slot * 80) + 'ms';
        slot++;
      }
    });

    var obs = new IntersectionObserver(function (changes) {
      changes.forEach(function (c) {
        if (c.isIntersecting) {
          c.target.classList.add('ink-visible');
          obs.unobserve(c.target);
        }
      });
    }, { threshold: 0.1 });

    [header, rule].concat(entries).forEach(function (el) { if (el) obs.observe(el); });
  }

  document.addEventListener('DOMContentLoaded', initReveal);
  document.addEventListener('astro:page-load', initReveal);
</script>
</BaseLayout>
