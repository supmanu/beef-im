---
import StaticPageLayout from '../layouts/StaticPageLayout.astro';
---
<StaticPageLayout
  title="ติดต่อ"
  description="ส่งอีเมลมาตรงๆ — beef.im"
>
  <span class="sp-eyebrow">CONTACT</span>
  <h1>ติดต่อ</h1>
  <hr class="sp-rule" />

  <p>
    <strong>Email:</strong> <a href="mailto:hello@beef.im" class="contact-link">hello@beef.im</a>
  </p>

  <p>
    ตอบภายใน 1–2 วันทำการ
    ถ้าเป็นเรื่องกรมธรรม์ที่อยากให้วิเคราะห์ — แนบสำเนากรมธรรม์มาด้วยเลย
    ไม่ต้องเกริ่นนำ
  </p>

  <p class="contact-status">
    <span class="status-dot">🟢</span>
    รับงานอยู่
  </p>
</StaticPageLayout>

<style>
.contact-link {
  color: var(--color-burn);
  text-decoration: none;
}
.contact-link:hover { text-decoration: underline; }
.contact-status {
  display: flex;
  align-items: center;
  gap: 8px;
  font-family: var(--font-mono);
  font-size: 12px;
  color: rgba(27,26,23,0.55);
  letter-spacing: 0.06em;
  margin-top: 32px;
}
.status-dot { font-size: 10px; }
</style>
