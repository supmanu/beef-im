---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="ค้นหา | ประกันเนื้อๆ"
  description="ค้นหาบทความใน beef.im"
  bodyClass="static-page"
>
  <div class="sp-wrap">
    <nav class="sp-nav">
      <a href="/" class="sp-brand">
        ประกันเนื้อๆ
        <small>BEEF · IM</small>
      </a>
      <a href="/#journal" class="sp-back">← สมุดบันทึก</a>
    </nav>
    <div class="sp-content">
      <span class="sp-eyebrow">SEARCH</span>
      <h1>ค้นหา</h1>
      <hr class="sp-rule" />

      <div id="search-box"></div>
      <div id="search-results"></div>
    </div>
  </div>
</BaseLayout>

<!-- Pagefind UI — only loads on this page -->
<link href="/pagefind/pagefind-ui.css" rel="stylesheet" />
<script src="/pagefind/pagefind-ui.js" type="text/javascript"></script>
<script>
  window.addEventListener('DOMContentLoaded', () => {
    // @ts-ignore — PagefindUI injected by pagefind CLI
    new PagefindUI({ element: '#search-box', showImages: false });
  });
</script>

<style>
/* Inherit StaticPageLayout styles via global.css sp-* classes */
.sp-wrap {
  min-height: 100vh;
  background:
    linear-gradient(90deg, rgba(120,100,75,0.11) 1px, transparent 1px),
    linear-gradient(180deg, rgba(120,100,75,0.11) 1px, transparent 1px),
    linear-gradient(180deg, #F0EADC 0%, #EDE7D8 100%);
  background-size: 24px 24px, 24px 24px, auto;
  color: #1B1A17;
}
.sp-nav {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 18px 24px 16px;
  border-bottom: 1px solid rgba(120,100,75,0.14);
  background: rgba(240,234,220,0.92);
  backdrop-filter: blur(4px);
  position: sticky;
  top: 0;
  z-index: 10;
}
.sp-brand {
  font-family: var(--font-display);
  font-weight: 700;
  font-size: 16px;
  letter-spacing: -0.01em;
  color: #1B1A17;
  text-decoration: none;
  line-height: 1.2;
}
.sp-brand small {
  display: block;
  font-family: var(--font-mono);
  font-size: 8px;
  color: rgba(27,26,23,0.42);
  letter-spacing: 0.22em;
  text-transform: uppercase;
  margin-top: 1px;
}
.sp-back {
  font-family: var(--font-mono);
  font-size: 10px;
  color: var(--color-burn);
  text-decoration: none;
  letter-spacing: 0.08em;
}
.sp-content {
  max-width: 680px;
  margin: 0 auto;
  padding: 48px 24px 80px;
}
.sp-eyebrow {
  font-family: var(--font-mono);
  font-size: 10px;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--color-burn);
  margin-bottom: 20px;
  display: block;
}
h1 {
  font-family: var(--font-display);
  font-weight: 800;
  font-size: clamp(28px, 5vw, 40px);
  letter-spacing: -0.025em;
  line-height: 1.15;
  margin-bottom: 8px;
  color: #1B1A17;
}
hr.sp-rule {
  border: none;
  border-top: 1.5px solid #CC3A2F;
  width: 48px;
  margin: 36px 0;
  opacity: 0.7;
}

/* Pagefind UI theme overrides */
:root {
  --pagefind-ui-scale: 0.9;
  --pagefind-ui-primary: var(--color-burn);
  --pagefind-ui-text: #1B1A17;
  --pagefind-ui-background: rgba(240,234,220,0.6);
  --pagefind-ui-border: rgba(120,100,75,0.25);
  --pagefind-ui-tag: #EDE7D7;
  --pagefind-ui-font: var(--font-thai, "Sarabun", sans-serif);
}
</style>
