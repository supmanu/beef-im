---
import BaseLayout from './BaseLayout.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  collection: string;
  format?: string;
  date: string;
  footerType: 'analysis' | 'beef' | 'note';
  code?: string;
  sidenote?: string;
}

const { title, description, collection, format, date, footerType, code, sidenote } = Astro.props;

// format frontmatter wins; fall back to collection-derived label
const collectionBadgeMap: Record<string, string> = {
  insurance: 'CASE FILE',
  meat: 'EXPERIMENT LOG',
  note: 'บันทึก',
};
const displayBadge = format ?? collectionBadgeMap[collection] ?? collection.toUpperCase();

// Footer stamp per collection
const footerStampMap: Record<string, string> = {
  insurance: '⚠ HIGH',
  meat: '🔥 MED RARE',
  note: '📝 NOTE',
};
const footerStamp = footerStampMap[collection] ?? '📝';

const pageNum = code ? `ID ${code}` : 'หน้า 01';
---
<BaseLayout title={`${title} | ประกันเนื้อๆ`} description={description} bodyClass="article-page">
  <section class="article-view active" id="article">
    <nav class="article-nav">
      <a href="/#journal" class="article-nav-back">← กลับหน้าหลัก</a>
      <span class="article-nav-stamp">{displayBadge}</span>
      <span class="article-nav-date">{date}</span>
    </nav>
    <div class="nb-article-body">
      <div class="nb-article-wrap">
        <slot />

        <div class="nb-page-footer">
          <div class="nb-page-footer-left">
            {date}
            <br />
            สมุดบันทึก · เล่ม 1
          </div>
          <div class="nb-page-footer-right">
            <svg viewBox="0 0 100 100">
              <ellipse cx="50" cy="50" rx="44" ry="42" transform="rotate(-2 50 50)"/>
              <text x="50" y="50">{footerStamp}</text>
            </svg>
            <div class="nb-page-num">{pageNum}</div>
          </div>
        </div>

        <Footer type={footerType} />
      </div>
    </div>
  </section>
</BaseLayout>
