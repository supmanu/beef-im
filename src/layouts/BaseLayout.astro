---
import '../styles/global.css';
interface Props {
  title: string;
  description?: string;
}
const { title, description = 'ประกันเนื้อๆ — BEEF · IM · JOURNAL' } = Astro.props;
---
<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{title}</title>
  <meta name="description" content={description}>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Anuphan:wght@400;500;700;800&family=IBM+Plex+Mono:wght@400;500;600&family=K2D:ital,wght@1,300&family=Noto+Serif+Thai:wght@400;700&family=Sarabun:wght@400;500;700&display=swap" rel="stylesheet">
</head>
<body>
  <slot />
</body>
</html>
