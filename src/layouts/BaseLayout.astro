---
import '@fontsource/anuphan/400.css';
import '@fontsource/anuphan/500.css';
import '@fontsource/anuphan/700.css';
import '@fontsource/ibm-plex-mono/400.css';
import '@fontsource/ibm-plex-mono/500.css';
import '@fontsource/ibm-plex-mono/600.css';
import '@fontsource/k2d/300.css';
import '@fontsource/k2d/300-italic.css';
import '@fontsource/sarabun/400.css';
import '@fontsource/sarabun/400-italic.css';
import '@fontsource/sarabun/500.css';
import '@fontsource/sarabun/700.css';
import '../styles/global.css';
import SiteFooter from '../components/SiteFooter.astro';
interface Props {
  title: string;
  description?: string;
  bodyClass?: string;
}
const { title, description = 'ประกันเนื้อๆ — BEEF · IM · JOURNAL', bodyClass = '' } = Astro.props;
---
<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <!-- Preload LCP font (Thai subset, 700 weight — hero heading) -->
  <!-- Note: update hash if @fontsource/anuphan package version changes -->
  <link rel="preload" href="/_astro/anuphan-thai-700-normal.rOsLv-jZ.woff2" as="font" type="font/woff2" crossorigin="anonymous">
  <!-- Preload body font (Thai subset, 400 weight) — breaks longest chain in font cascade -->
  <!-- Note: update hash if @fontsource/sarabun package version changes -->
  <link rel="preload" href="/_astro/sarabun-thai-400-normal.C2DaJlKK.woff2" as="font" type="font/woff2" crossorigin="anonymous">
  <title>{title}</title>
  <meta name="description" content={description}>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:type" content="website">
  <meta property="og:locale" content="th_TH">
  <meta name="twitter:card" content="summary">
</head>
<body class={bodyClass}>
  <main>
    <slot />
  </main>
  <SiteFooter />
</body>
</html>
